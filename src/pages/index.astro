  <footer style="background: var(--dark); color: var(--white); padding: 2rem; text-align: center;">
    <p>&copy; 2026 Daily Smoothies. All rights reserved.</p>
    <p style="margin-top: 1rem; font-size: 0.9rem; opacity: 0.8;">
      <a href="/privacy" style="color: var(--white); margin: 0 1rem;">Privacy Policy</a> | 
